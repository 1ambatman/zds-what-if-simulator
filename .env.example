# Databricks SQL warehouse (required for loading profiles from UC tables)
#
# Option A — explicit .env (good for CI or when not using ~/.databrickscfg):
DATABRICKS_HOST=https://adb-3834014070274745.5.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxx
DATABRICKS_TOKEN=dapixxxxxxxx
#
# Option B — AI dev kit / Cursor MCP style (`databricks auth login`, no PAT):
# Set DATABRICKS_CONFIG_PROFILE=DEFAULT (optional if you only have one profile).
# Leave DATABRICKS_TOKEN unset. Host + OAuth come from ~/.databrickscfg.
# If an expired PAT is still in this file or your shell, MLflow will 403 — either remove DATABRICKS_TOKEN
# or set DATABRICKS_OAUTH_ONLY=true so the app ignores it and uses OAuth only.
# DATABRICKS_OAUTH_ONLY=true
# You still need the SQL warehouse id (Compute → SQL warehouses → open warehouse → copy id from URL or HTTP path):
# DATABRICKS_WAREHOUSE_ID=<uuid>
# or DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<uuid>

# MLflow on Databricks — used to load the LightGBM model from a run
MLFLOW_TRACKING_URI=databricks
# With a PAT (DATABRICKS_TOKEN set), MLflow uses the URIs above.
# With OAuth only (no DATABRICKS_TOKEN), the app overrides to databricks://<profile> and
# databricks-uc://<profile> (profile = DATABRICKS_CONFIG_PROFILE or DEFAULT) so MLflow uses the SDK.

# Defaults (override in UI or here)
PREDICTIONS_TABLE=mle.batch_model_inference.predictions
MLFLOW_RUN_ID=9d740e9e5f544d9490100cef238bf074
# auto = discover folder that contains MLmodel | or set explicit path e.g. model or nested/path/model
# MLFLOW_MODEL_ARTIFACT_PATH=auto
# Or load from Unity Catalog Model Registry instead of a run path:
# MLFLOW_MODEL_URI=models:/catalog.schema.registered_model_name/1

# Optional: load model from a local MLflow model directory instead of the run
# LOCAL_MODEL_PATH=/path/to/mlartifacts/model
#
# For runs, the app downloads via Databricks Files API (workspace HTTPS) first; MLflow only falls
# back to Azure blob presigned URLs if that fails (those URLs often hit SSLEOF behind VPN/proxy).
#
# Integration tests: `pytest tests/ -m "integration and not slow"` (SQL + warehouse).
# Optional live MLflow load test: `RUN_LIVE_DATABRICKS_MLFLOW=1 pytest tests/ -m slow` (needs stable network).
